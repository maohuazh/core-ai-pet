<Window x:Class="CoreAIpet.Desktop.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CoreAIpet Debug" Width="600" Height="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="性能指标" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="FpsText" Text="FPS: --"/>
            <TextBlock x:Name="CpuText" Text="CPU: --"/>
            <TextBlock x:Name="MemText" Text="Memory: --"/>
            <TextBlock Text="插件状态" FontWeight="Bold" Margin="0,15,0,5"/>
            <ListBox x:Name="PluginList" Height="150"/>
        </StackPanel>
        <DockPanel Grid.Column="1">
            <TextBlock Text="日志" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,5"/>
            <ListBox x:Name="LogList" FontFamily="Consolas" FontSize="11"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </DockPanel>
    </Grid>
</Window>
