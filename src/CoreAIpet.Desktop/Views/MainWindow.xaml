<Window x:Class="CoreAIpet.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CoreAIpet.Desktop.Controls"
        Title="CoreAIpet"
        Width="280" Height="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- 外边距作为透明区域 -->
    <Grid Margin="20">
        <!-- 卡片背景 + 阴影 -->
        <Border Background="#FF2B3A6B"
                CornerRadius="16"
                BorderBrush="#80FFFFFF"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.6" Color="Black"/>
            </Border.Effect>
        </Border>

        <!-- 内容 -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 角色区域：使用 WPF Canvas 占位角色 -->
            <Border Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <controls:PetCharacterControl x:Name="CharacterDisplay"
                                              Width="200"
                                              Height="240"/>
            </Border>

            <!-- 底部信息 -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0">
                <TextBlock Text="CoreAIpet"
                           FontSize="18" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           FontFamily="Microsoft YaHei UI"/>
                <TextBlock Text="鼠标移动 → 眼球跟随"
                           FontSize="11"
                           Foreground="#A0FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           FontFamily="Microsoft YaHei UI"/>
            </StackPanel>

            <!-- 径向菜单 -->
            <controls:RadialMenuControl x:Name="RadialMenu"
                Width="200" Height="200"
                Visibility="Collapsed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
