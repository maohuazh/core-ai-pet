<Window x:Class="CoreAIpet.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CoreAIpet 设置" Width="500" Height="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <TabControl Padding="10">
        <TabItem Header="外观">
            <StackPanel Margin="10">
                <TextBlock Text="角色大小" Margin="0,0,0,5"/>
                <Slider x:Name="ScaleSlider" Minimum="50" Maximum="200" Value="100" TickFrequency="10" IsSnapToTickEnabled="True"/>
                <TextBlock Text="透明度" Margin="0,15,0,5"/>
                <Slider x:Name="OpacitySlider" Minimum="20" Maximum="100" Value="100" TickFrequency="5" IsSnapToTickEnabled="True"/>
                <TextBlock Text="主题" Margin="0,15,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Light" Margin="0,0,20,0"/>
                    <RadioButton Content="Dark" IsChecked="True"/>
                </StackPanel>
            </StackPanel>
        </TabItem>
        <TabItem Header="系统">
            <StackPanel Margin="10">
                <CheckBox Content="开机启动" Margin="0,5"/>
                <CheckBox Content="窗口置顶" IsChecked="True" Margin="0,5"/>
                <CheckBox Content="点击穿透" Margin="0,5"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="AI">
            <StackPanel Margin="10">
                <TextBlock Text="AI 后端" Margin="0,0,0,5"/>
                <ComboBox x:Name="ProviderCombo" Margin="0,0,0,10">
                    <ComboBoxItem Content="OpenAI" IsSelected="True"/>
                    <ComboBoxItem Content="Azure OpenAI"/>
                    <ComboBoxItem Content="Ollama"/>
                </ComboBox>
                <TextBlock Text="Endpoint" Margin="0,0,0,5"/>
                <TextBox x:Name="EndpointBox" Margin="0,0,0,10"/>
                <TextBlock Text="API Key" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,10"/>
                <TextBlock Text="Model" Margin="0,0,0,5"/>
                <TextBox x:Name="ModelBox" Margin="0,0,0,10"/>
                <Button Content="测试连接" Width="100" HorizontalAlignment="Left"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
