<Window x:Class="CoreAIpet.Desktop.Views.ChatBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight">
    <Border Background="#F0F0F0" CornerRadius="12" Padding="12" Margin="10"
            BorderBrush="#CCC" BorderThickness="1">
        <StackPanel MaxWidth="350">
            <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                     MaxHeight="120" MaxLength="4000"
                     KeyDown="InputBox_KeyDown"
                     VerticalScrollBarVisibility="Auto"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                <Button Content="发送" Click="SendButton_Click" Padding="15,3"
                        Background="#4A90D9" Foreground="White" BorderThickness="0"/>
            </StackPanel>
            <TextBlock x:Name="ResponseText" TextWrapping="Wrap" Margin="0,8,0,0"
                       MaxHeight="200" Visibility="Collapsed"/>
            <Button x:Name="ViewMoreButton" Content="查看更多" Visibility="Collapsed"
                    Click="ViewMore_Click" HorizontalAlignment="Left" Margin="0,2,0,0"
                    Foreground="#4A90D9" Cursor="Hand" BorderThickness="0" Background="Transparent"/>
        </StackPanel>
    </Border>
</Window>
